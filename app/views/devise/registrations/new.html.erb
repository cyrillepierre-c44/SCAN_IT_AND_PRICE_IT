<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card border-0 shadow-lg">
        <div class="card-body p-5">
          <div class="text-center mb-4">
            <h2 class="fw-bold">Créer un compte</h2>
            <p class="text-muted">Rejoignez Le Prix Juste</p>
          </div>

          <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
            <%= f.error_notification %>

            <div class="mb-3">
              <%= f.input :email,
                label: "Email",
                required: true,
                autofocus: true,
                input_html: { class: "form-control", placeholder: "votre@email.com" } %>
            </div>

            <div class="mb-3">
              <%= f.input :password,
                label: "Mot de passe",
                required: true,
                hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
                input_html: { class: "form-control", placeholder: "••••••••" } %>
            </div>

            <div class="mb-3">
              <%= f.input :password_confirmation,
                label: "Confirmation du mot de passe",
                required: true,
                input_html: { class: "form-control", placeholder: "••••••••" } %>
            </div>

            <div class="d-grid">
              <%= f.button :submit, "S'inscrire", class: "btn btn-primary btn-lg" %>
            </div>
          <% end %>

          <hr class="my-4">

          <div class="text-center">
            <%= render "devise/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
