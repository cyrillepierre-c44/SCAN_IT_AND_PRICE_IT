<div class="hero-section">
  <div class="container">
    <div class="row align-items-center min-vh-75">
      <div class="col-lg-6">
        <h1 class="display-4 fw-bold mb-4">Qui sommes-nous ?</h1>
        <p class="lead mb-4">Notre savoir-faire et l'IA au service du jouet solidaire.</p>
        <p class="mb-4">
          Découvrez notre mission, notre approche innovante et notre engagement envers l'économie sociale et solidaire.
        </p>
      </div>

<div class="features-section py-5">
  <div class="container">
    <h2 class="text-center mb-5">Notre engagement</h2>
    <div class="row text-center">
      <div class="col-md-4 mb-4">
        <div class="feature-icon mb-3">
          <i class="fas fa-bullseye"></i>
        </div>
        <h3>Notre mission</h3>
        <p>
          Permettre d'associer notre savoir à l'IA au quotidien pour
          s'adapter à la demande de structure qui réinsert des personnes.
        </p>
      </div>
      <div class="col-md-4 mb-4">
        <div class="feature-icon mb-3">
          <i class="fas fa-lightbulb"></i>
        </div>
        <h3>Notre approche</h3>
        <p>
          Révolutionner l'existant en proposant la siplification par l'automatisation et l'IA.
        </p>
      </div>
      <div class="col-md-4 mb-4">
        <div class="feature-icon mb-3">
          <i class="fas fa-handshake"></i>
        </div>
        <h3>Notre engagement</h3>
        <p>
          Mettre en place des solutions disruptifs et innovantes.
        </p>
      </div>
    </div>
  </div>
</div>

<!-- Section 3 visuels -->
<div style="display:flex; gap:20px; justify-content:center; margin-top:40px; flex-wrap:wrap;">

  <div style="width:180px; text-align:center;">
    <%= image_tag "photo_cyrille.jpg", style: "width:100%; height:auto; border-radius:12px;" %>
    <p style="margin-top:10px;">Operation manager.</p>
     <p><%= link_to "Voir le parcours de Cyrille", cyrille_path %></p>
  </div>

   <div style="width:180px; text-align:center;">
    <%= image_tag "photo_loic.jpg", style: "width:100%; height:auto; border-radius:12px;" %>
    <p style="margin-top:10px;">Designer et consultant en financement public.</p>
    <p><%= link_to "Voir le parcours de Loïc.", loic_path %></p>
  </div>

   <div style="width:180px; text-align:center;">
    <%= image_tag "photo_marc.jpg", style: "width:100%; height:auto; border-radius:12px;" %>
    <p style="margin-top:10px;">Consultant en financement de projets dans un cabinet de conseil.</p>
    <p><%= link_to "Voir le parcours de Marc.", marc_path %></p>
  </div>

</div>
