<div class="container py-4">
  <div class="row">
    <div class="col-lg-8">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Archive des demandes</h2>
        <%= link_to "Nouvelle demande", requests_new_path, class: "btn btn-primary" %>
      </div>

      <% if @requests.any? %>
        <div class="row g-3">
          <% @requests.each do |request| %>
            <div class="col-12">
              <div class="card border-0 shadow-sm">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-start">
                    <div>
                      <h5 class="card-title mb-1">
                        <%= link_to "Demande ##{request.id}", request_path(request), class: "text-decoration-none text-dark" %>
                      </h5>
                      <small class="text-muted">
                        <%= request.created_at.strftime("Créée le %d/%m/%Y") %>
                      </small>
                    </div>
                    <div class="badge bg-light text-dark">
                      <%= request.chats.count %> discussion(s)
                    </div>
                  </div>

                  <div class="d-flex flex-wrap gap-2 mt-2">
                    <span class="badge <%= request.fullness ? 'bg-success' : 'bg-warning text-dark' %>">
                      <%= request.fullness ? 'Complet' : 'Incomplet' %>
                    </span>
                    <span class="badge <%= request.newness ? 'bg-info text-dark' : 'bg-secondary' %>">
                      <%= request.newness ? 'Neuf' : 'Occasion' %>
                    </span>
                    <span class="badge bg-primary">
                      <%= request.cleanliness || 'Non spécifié' %>
                    </span>
                  </div>

                  <% if request.photo.attached? %>
                    <div class="mt-2">
                      <%= image_tag request.photo, class: "rounded", height: 100 %>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-5">
          <p class="text-muted mb-3">Aucune demande pour le moment</p>
          <%= link_to "Créer une demande", requests_new_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>

    <div class="col-lg-4 mt-4 mt-lg-0">
      <div class="position-sticky" style="top: 100px;">
        <div class="card border-0 shadow">
          <%= image_tag "oursons.png", class: "card-img-top", alt: "Oursons en peluche", style: "transform: scale(0.9);" %>
          <div class="card-body text-center">
            <h5 class="card-title">Le Prix Juste</h5>
            <p class="card-text text-muted">Estimez la valeur de vos jouets</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
