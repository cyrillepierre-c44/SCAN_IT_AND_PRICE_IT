<div class=main-container>
  <div class="row">
    <div class="col">
      <h1>Demande N°<%= @request.id %></h1>

    </div>
    <div class="col-md-3">
      <h2>Discussions existantes</h2>
      <div class="mb-4">
        <% if @chats.any? %>
          <ul>
            <% @chats.each do |chat| %>
              <li><%= link_to chat.title, chat_path(chat) %></li>
            <% end %>
          </ul>
        <% else %>
          Il n'y a pas de encore de discussion
        <% end %>
      </div>
    </div>
  </div>

<p>--------------------------------------------------------------------------</p>

  <div class="row">
    <div class="col">
      <h2>L'état de propreté de l'objet est : <%= @request.cleanliness %></h2>
      <h2>Est-il complet ? : <%= @request.fullness %></h2>
      <h2>Est-il neuf ? : <%= @request.newness %></h2>
    </div>
    <div class="col-md-3">
      <!-- ... -->
      <%= button_to "Nouvelle discussion", request_chats_path(@request), class: "btn btn-primary" %>
    </div>
  </div>
</div>
