  <div class="row">
    <div class="col">
      <h1><%= @request.id %></h1>
      <%= raw(@request.cleanliness) %>
    </div>
    <div class="col-md-3">
      <h2>Chats</h2>
      <div class="mb-4">
        <% if @chats.any? %>
          <ul>
            <% @chats.each do |chat| %>
              <li><%= link_to chat.title, chat_path(chat) %></li>
            <% end %>
          </ul>
        <% else %>
          There are no chats yet.
        <% end %>
            </div>
    </div>
  </div>
